###

POST {{OSTA.API_HostAddress}}/api/v1/bom-import-batches
Content-Type: application/json

{
  "sourceFileName": "sample-bom.csv",
  "importMode": "ExecutionOnly",
  "lines": [
    {
      "rowNumber": 1,
      "projectCode": "PRJ-BOM-001",
      "projectName": "Sample Project",
      "finishedGoodCode": "FG-BOM-001",
      "finishedGoodName": "Sample Finished Good",
      "assemblyCode": "ASM-BOM-001",
      "assemblyName": "Sample Assembly",
      "partNumber": "PART-BOM-001",
      "revision": "A",
      "description": "Imported sample part",
      "quantity": 2,
      "materialCode": "AL-5052",
      "thicknessMm": 4.0,
      "weightKg": 9.8,
      "notes": "Audit sample line",
      "processRouteCode": "ROUTE-01",
      "cutOnly": true
    }
  ]
}

###

POST {{OSTA.API_HostAddress}}/api/v1/bom-import-batches/from-template
Content-Type: application/json

{
  "templateCode": "QCC_MTO_CSV_V1",
  "sourceFileName": "qcc-mto.csv",
  "importMode": "ExecutionAndProductDefinition",
  "csvContent": "project_code,assembly_code,part_code,part_name,qty,uom,material_code,thickness_mm,process_route,cut_only,weight_kg,notes\nPRJ-TPL-001,ASM-TPL-001,PART-TPL-001,Drive mounting plate,2,EA,STL-S275,6.0,CUT-DRILL,true,12.5,First QCC template line"
}

###

POST {{OSTA.API_HostAddress}}/api/v1/bom-import-batches/from-template
Content-Type: application/json

{
  "templateCode": "CONVEYOR_BOM_V1",
  "sourceFileName": "conveyor-bom.csv",
  "importMode": "ExecutionOnly",
  "defaultValues": {
    "ProjectCode": "PRJ-CONVEYOR-TPL-001",
    "ProjectName": "Conveyor Template Project"
  },
  "csvContent": "ParentItemCode,ParentItemName,ComponentItemCode,ComponentItemName,PartNumber,Revision,Description,Quantity\nMCB-0600X0075,Modular Belt Conveyor 600x75,MCB-0600X0075-DRIVE,Drive Unit Assembly,DRV-PLATE-001,A,Drive mounting plate,1"
}

###

POST {{OSTA.API_HostAddress}}/api/v1/bom-import-batches/from-template
Content-Type: application/json

{
  "templateCode": "CONVEYOR_BOM_LEVELLED_V1",
  "sourceFileName": "conveyor-levelled-bom.csv",
  "importMode": "ExecutionOnly",
  "defaultValues": {
    "ProjectCode": "PRJ-CONVEYOR-LVL-001",
    "ProjectName": "Conveyor Levelled Template Project"
  },
  "csvContent": "Level,ParentCode,ItemNo,ComponentCode,Description,Qty,UoM,ItemType,ProcurementType,Revision,Material,ThicknessMM,WeightKG,Notes\n0,,0000,MCB-0600X0075,Modular Belt Conveyor 600x75,1,EA,FinishedGood,Make,A,,,\n1,MCB-0600X0075,0010,MCB-0600X0075-DRIVE,Drive Unit Assembly,1,EA,Assembly,Make,A,,,"
}

